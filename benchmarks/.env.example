# Neon Postgres — pgvector-enabled database for storing chunks, entities, and graph data
NEON_DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Neon API key — used by management scripts (not required for running benchmarks)
NEON_API_KEY=napi_xxx

# Vercel AI Gateway — unified API key for embeddings (text-embedding-3-small) and LLM calls (gpt-5.4-mini, grok-4.20-reasoning)
AI_GATEWAY_API_KEY=xxx

# Vercel Blob — read/write token for fetching benchmark datasets (corpus, queries, qrels, answers)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# Hugging Face — token for downloading datasets from HuggingFace Hub (used by seed scripts)
HF_TOKEN=hf_xxx
